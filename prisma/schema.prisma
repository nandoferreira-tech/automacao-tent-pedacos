// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Cliente — identificado pelo número de WhatsApp
model Customer {
  phone      String   @id              // número no formato internacional ex: 5511999999999
  name       String
  // campos preenchidos apenas no cadastro do programa de fidelidade
  email      String?
  birthDate  DateTime?
  neighborhood String?
  city       String?
  cep        String?
  howFound   String?
  lastAddress  String?              // último endereço de entrega confirmado
  points       Int      @default(0)
  createdAt    DateTime @default(now())

  orders       Order[]
  loyaltyTxns  LoyaltyTransaction[]
}

// Produto do cardápio
model Product {
  id          String  @id @default(cuid())
  category    String  // "bolos-no-pote" | "bolos-artesanais"
  subcategory String? // "tradicional" | "especial" | "cobertura"
  name        String
  description String?
  price       Float
  isAddon     Boolean @default(false) // true = cobertura (item adicional, sempre opcional)
  available   Boolean @default(true)

  orderItems OrderItem[]
}

// Pedido
model Order {
  id            String      @id @default(cuid())
  customerPhone String
  customerName  String
  deliveryType  String      // "retirada" | "entrega"
  address       String?
  status        String      @default("aguardando_pagamento")
  // aguardando_pagamento | pago | em_producao | pronto | saiu_entrega | entregue | cancelado
  paymentMethod String      // "pix" | "cartao_entrega" | "dinheiro_entrega"
  pixCode           String?     // linha digitável gerada
  pixQr             String?     // qr code base64
  total             Float
  orderNumber       Int?
  comprovanteUrl    String?
  comprovanteStatus String?
  notaInterna       String?
  deliveryTime  DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  customer  Customer    @relation(fields: [customerPhone], references: [phone])
  items     OrderItem[]
}

// Itens do pedido (N:N entre Order e Product)
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// Histórico de pontos de fidelidade
model LoyaltyTransaction {
  id          String   @id @default(cuid())
  phone       String
  points      Int      // positivo = ganho, negativo = resgate
  description String
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [phone], references: [phone])
}

// Estado da conversa ativa (contexto do agente por número)
model Conversation {
  phone     String   @id
  state     String   @default("idle")
  // idle | menu | pedido_categoria | pedido_produto | pedido_entrega | pedido_pagamento | cadastro
  context   String   @default("{}") // JSON serializado com dados parciais da conversa
  history   String   @default("[]") // JSON: Array<{ role: 'user' | 'model'; text: string }>
  updatedAt DateTime @updatedAt
}
