# =============================================================================
# .env — Produção
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais!
# =============================================================================

NODE_ENV=production

# --- WhatsApp ---
WPP_ENABLED=true

# --- Banco de dados ---
DATABASE_URL="file:./prod.db"

# --- Google ---
GOOGLE_API_KEY=          # Gemini LLM + Maps
GOOGLE_MAPS_API_KEY=     # Pode ser igual ao GOOGLE_API_KEY

# --- OpenPix / Woovi ---
OPENPIX_APP_ID=          # Conta de PRODUÇÃO da Woovi

# --- WhatsApp ---
WPP_SESSION_NAME=agente-prod     # Nome da sessão de produção
COMPANY_PHONE=5511999999999      # Número que recebe notificações de pedidos
PIX_PHONE=5511969585343          # Chave Pix (telefone) para receber pagamentos

# --- Agente ---
AGENT_NAME=Tentação em Pedaços
CUTOFF_HOUR=17

# --- Entrega ---
STORE_ADDRESS=Rua Padre Carvalho, 388, São Paulo, SP
DELIVERY_RADIUS_KM=5

# --- Servidor interno (comunicação agente ↔ dashboard) ---
INTERNAL_PORT=3001

# --- Provedor WhatsApp ---
# wwebjs    → whatsapp-web.js (padrão, gratuito, sem dependências externas)
# evolution → Evolution API   (migrar quando quiser usar Meta Cloud API pago)
WHATSAPP_PROVIDER=wwebjs

# Evolution API (preencher apenas se WHATSAPP_PROVIDER=evolution)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=agente-prod
EVOLUTION_WEBHOOK_PORT=3002

# --- Dashboard ---
AGENT_INTERNAL_URL=http://localhost:3001
DASHBOARD_PASSWORD=           # TROQUE por senha forte
DASHBOARD_SECRET=             # openssl rand -base64 32
