# =============================================================================
# .env — Homologação
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais!
# =============================================================================

NODE_ENV=development

# --- WhatsApp ---
# false = sobe sem conectar ao WhatsApp (homolog usa 1 número com prod)
WPP_ENABLED=false

# --- Banco de dados ---
DATABASE_URL="file:./homolog.db"

# --- Google ---
GOOGLE_API_KEY=AIzaSyCDwClHHgtUyoQXic2wh5oXa_BCxwCC_S8        # usada para Gemini (LLM) e Maps (validação de endereço)
GOOGLE_MAPS_API_KEY=AIzaSyCDwClHHgtUyoQXic2wh5oXa_BCxwCC_S8     # pode ser a mesma key se o projeto tiver ambas as APIs habilitadas

# --- OpenPix / Woovi ---
OPENPIX_APP_ID=          # Conta de TESTES da Woovi

# --- WhatsApp ---
WPP_SESSION_NAME=agente-homolog   # Nome da sessão (identifica o arquivo de sessão salvo)
COMPANY_PHONE=5511984380212  # número da empresa que recebe notificações e comprovantes
PIX_PHONE=5511991516261      # chave Pix (telefone) para receber pagamentos

# --- Agente ---
AGENT_NAME=Tentação em Pedaços (Homolog)
CUTOFF_HOUR=17

# --- Entrega ---
STORE_ADDRESS=Rua Padre Carvalho, 388, São Paulo, SP
DELIVERY_RADIUS_KM=5

# --- Servidor interno (comunicação agente ↔ dashboard) ---
INTERNAL_PORT=3101

# --- Provedor WhatsApp ---
WHATSAPP_PROVIDER=wwebjs

# Evolution API (preencher apenas se WHATSAPP_PROVIDER=evolution)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=agente-homolog
EVOLUTION_WEBHOOK_PORT=3102

# --- Dashboard ---
# URL do servidor interno do agente (usada pelo Next.js para enviar notificações)
AGENT_INTERNAL_URL=http://localhost:3101
DASHBOARD_PASSWORD=homolog123       # Senha de acesso ao dashboard
DASHBOARD_SECRET=TROQUE_POR_32_CHARS_ALEATORIOS   # openssl rand -base64 32
