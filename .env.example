# Banco de dados
DATABASE_URL="file:./dev.db"

# Google
GOOGLE_API_KEY=          # usada para Gemini (LLM) e Maps (validação de endereço)
GOOGLE_MAPS_API_KEY=     # pode ser a mesma key se o projeto tiver ambas as APIs habilitadas

# OpenPix / Woovi — geração de cobranças Pix
OPENPIX_APP_ID=          # obtido em: app.woovi.com > Configurações > Aplicativos > APIs

# WhatsApp
WPP_SESSION_NAME=agente-wpp
COMPANY_PHONE=5511999999999   # número da empresa que recebe notificações e comprovantes
PIX_PHONE=5511969585343       # chave Pix (telefone) para receber pagamentos

# Agente
AGENT_NAME=Tentação em Pedaços
CUTOFF_HOUR=17                # pedidos após esse horário → entrega no dia seguinte
